# Copia questo file in .env e compila i valori reali
# NON committare .env nel repository

# Chiave API Google Gemini (ottienila su https://aistudio.google.com/)
GEMINI_API_KEY=la-tua-chiave-api-gemini

# Modello Gemini da usare
GEMINI_MODEL=gemini-2.5-flash

# URI del database
# Sviluppo locale: SQLite
SQLALCHEMY_DATABASE_URI=sqlite:///app.db
# Produzione: PostgreSQL
# SQLALCHEMY_DATABASE_URI=postgresql://user:password@host:5432/dbname

# Chiave segreta per firmare i JWT (deve essere lunga e casuale)
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
PRIVATE_APP_KEY=sostituisci-con-una-stringa-casuale-lunga-almeno-32-caratteri

# URL di connessione Redis
# Con Docker Compose usa il nome del servizio "redis"
REDIS_URL=redis://redis:6379
# In locale senza Docker:
# REDIS_URL=redis://localhost:6379
